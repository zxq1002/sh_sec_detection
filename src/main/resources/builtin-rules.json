{
  "version": "1.1",
  "rules": [
    {
      "id": "builtin-rm-rf",
      "name": "rm -rf dangerous",
      "type": "BLACKLIST",
      "pattern": "\\brm\\s+.*-rf",
      "riskLevel": "DANGER",
      "description": "递归删除指令（含根目录删除风险）",
      "enabled": true
    },
    {
      "id": "builtin-mkfs",
      "name": "mkfs",
      "type": "BLACKLIST",
      "pattern": "\\bmkfs\\..*",
      "riskLevel": "DANGER",
      "description": "格式化文件系统",
      "enabled": true
    },
    {
      "id": "builtin-dd",
      "name": "dd dangerous",
      "type": "BLACKLIST",
      "pattern": "\\bdd.*of=/dev/",
      "riskLevel": "DANGER",
      "description": "dd 直接写入物理设备",
      "enabled": true
    },
    {
      "id": "builtin-reboot",
      "name": "reboot/shutdown",
      "type": "BLACKLIST",
      "pattern": "\\breboot\\b|\\bshutdown\\b|\\binit\\s+[06]\\b|\\bsystemctl\\s+(poweroff|reboot)|\\bhalt\\b|\\bpoweroff\\b",
      "riskLevel": "DANGER",
      "description": "系统重启、关机或切换运行级别",
      "enabled": true
    },
    {
      "id": "builtin-cp-mv",
      "name": "cp/mv dangerous",
      "type": "BLACKLIST",
      "pattern": "\\bcp\\s+-f|\\bmv\\s+",
      "riskLevel": "RISK",
      "description": "强制复制或移动文件（可能覆盖关键配置）",
      "enabled": true
    },
    {
      "id": "builtin-touch-mkdir",
      "name": "touch/mkdir",
      "type": "BLACKLIST",
      "pattern": "\\btouch\\s+|\\bmkdir\\s+-p",
      "riskLevel": "RISK",
      "description": "创建文件或递归创建目录",
      "enabled": true
    },
    {
      "id": "builtin-sed-awk-perl",
      "name": "sed/awk/perl in-place",
      "type": "BLACKLIST",
      "pattern": "\\bsed\\s+-i|\\bawk\\s+-i.*inplace|\\bperl\\s+-i",
      "riskLevel": "RISK",
      "description": "利用文本处理工具原地修改系统文件",
      "enabled": true
    },
    {
      "id": "builtin-chmod-chown",
      "name": "permission/owner change",
      "type": "BLACKLIST",
      "pattern": "\\bchmod\\s+(777|-R)|\\bchown\\s+-R|\\bchgrp\\s+-R",
      "riskLevel": "RISK",
      "description": "递归修改权限或所有者",
      "enabled": true
    },
    {
      "id": "builtin-kill",
      "name": "force kill",
      "type": "BLACKLIST",
      "pattern": "\\b(kill|pkill|killall)\\s+-9",
      "riskLevel": "RISK",
      "description": "强制终止进程",
      "enabled": true
    },
    {
      "id": "builtin-file-write",
      "name": "file write redirection",
      "type": "BLACKLIST",
      "pattern": "\\s*>{1,2}\\s*[^\\s]",
      "riskLevel": "RISK",
      "description": "重定向写文件（含追加模式）",
      "enabled": true
    },
    {
      "id": "builtin-reverse-shell",
      "name": "reverse shell",
      "type": "BLACKLIST",
      "pattern": "/dev/(tcp|udp)/|\\bnc\\s+.*\\d+\\.\\d+\\.\\d+\\.\\d+|\\btelnet\\s+.*\\d+\\.\\d+\\.\\d+\\.\\d+|\\bbash\\s+-i",
      "riskLevel": "DANGER",
      "description": "反弹 Shell 特征检测",
      "enabled": true
    },
    {
      "id": "builtin-pipe-dangerous",
      "name": "dangerous pipe flow",
      "type": "BLACKLIST",
      "pattern": "\\|.*\\b(nc|telnet|bash|sh|zsh|python|perl|ruby|base64)\\b",
      "riskLevel": "DANGER",
      "description": "危险管道流（如管道后接 Shell 或 base64 解码）",
      "enabled": true
    },
    {
      "id": "builtin-ls",
      "name": "ls",
      "type": "WHITELIST",
      "pattern": "^\\s*ls\\b(?!.*[;|&<>$()`])",
      "riskLevel": "SAFE",
      "description": "安全查看目录",
      "enabled": true
    },
    {
      "id": "builtin-cat",
      "name": "cat",
      "type": "WHITELIST",
      "pattern": "^\\s*cat\\b(?!.*[;|&<>$()`])",
      "riskLevel": "SAFE",
      "description": "安全查看内容",
      "enabled": true
    },
    {
      "id": "builtin-echo",
      "name": "echo/printf",
      "type": "WHITELIST",
      "pattern": "^\\s*(echo|printf)\\b(?!.*[;|&<>$()`])",
      "riskLevel": "SAFE",
      "description": "安全输出文本",
      "enabled": true
    },
    {
      "id": "builtin-info",
      "name": "system info",
      "type": "WHITELIST",
      "pattern": "^\\s*(pwd|whoami|id|date|uptime)\\b(?!.*[;|&<>$()`])",
      "riskLevel": "SAFE",
      "description": "安全查询系统信息",
      "enabled": true
    },
    {
      "id": "builtin-process-view",
      "name": "process view",
      "type": "WHITELIST",
      "pattern": "^\\s*(ps|top)\\b(?!.*[;|&<>$()`])",
      "riskLevel": "SAFE",
      "description": "安全查看进程",
      "enabled": true
    },
    {
      "id": "builtin-file-view",
      "name": "file view",
      "type": "WHITELIST",
      "pattern": "^\\s*(head|tail|less|more)\\b(?!.*[;|&<>$()`])",
      "riskLevel": "SAFE",
      "description": "安全分页查看",
      "enabled": true
    },
    {
      "id": "builtin-search",
      "name": "search",
      "type": "WHITELIST",
      "pattern": "^\\s*(grep|find)\\b(?!.*[;|&<>$()`])",
      "riskLevel": "SAFE",
      "description": "安全搜索指令",
      "enabled": true
    },
    {
      "id": "builtin-su-sudo",
      "name": "su/sudo",
      "type": "BLACKLIST",
      "pattern": "\\b(su|sudo)\\b",
      "riskLevel": "RISK",
      "description": "权限提升指令（潜在越权或提权风险）",
      "enabled": true
    },
    {
      "id": "builtin-history",
      "name": "history clearing",
      "type": "BLACKLIST",
      "pattern": "\\bhistory\\s+-c|\\brm\\s+.*\\.bash_history",
      "riskLevel": "RISK",
      "description": "清理命令历史记录（疑似规避审计行为）",
      "enabled": true
    },
    {
      "id": "builtin-crontab",
      "name": "crontab modification",
      "type": "BLACKLIST",
      "pattern": "\\bcrontab\\s+(-e|-r|\\b\\w+\\b)",
      "riskLevel": "RISK",
      "description": "修改计划任务（疑似持久化提权行为）",
      "enabled": true
    }
  ]
}
